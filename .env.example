# OpenAI API 키 (news/summarize_descriptions.py가 사용)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_WAIT=1.5
OPENAI_BODY_LIMIT=4000

# 네이버 데이터랩 검색어트렌드 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# mim_terms가 있는 RDS (SSH 터널을 통해 접속) — 로컬 개발 전용
SSH_HOST=
SSH_PORT=22
SSH_USER=ec2-user
SSH_PEM_PATH=
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# 프로덕션(Docker/EC2)에서 SSH 터널 없이 직접 접속할 때 사용
# ex) postgres://user:password@10.0.2.55:5432/postgres
DATABASE_URL=
DB_SCHEMA=public
DB_TABLE=trending_word_enriched
DB_BATCH_SIZE=100

# careet.net 로그인 정보 (mim/get_mim_data.py)
CAREET_EMAIL=
CAREET_PASSWORD=

# trending_word_crawler 설정
WORD_LIMIT=0

# S3 저장 경로 설정
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
AWS_SESSION_TOKEN=
S3_ENDPOINT_URL=
S3_BUCKET=
S3_RAW_PREFIX=trending-word/raw
S3_ENRICHED_PREFIX=trending-word/enriched

# 주기 실행(스케줄러) 설정
PIPELINE_ENABLED=true
PIPELINE_SCHEDULE_CRON=0 3 * * *
PIPELINE_TIMEZONE=Asia/Seoul
