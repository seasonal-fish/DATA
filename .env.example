# 네이버 오픈API (데이터랩 검색어트렌드, 뉴스 검색에 공통으로 사용)
# https://developers.naver.com/apps 에서 애플리케이션 등록 후 발급

## 지수 아이디
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 모든 크롤러가 공통으로 사용하는 User-Agent. 사이트 운영자가 문의할 수 있도록
# 연락 가능한 정보를 포함하는 것을 권장한다 (예: 프로젝트명 + 이메일).
CRAWLER_USER_AGENT="ProjectNameBot/1.0 (+mailto:lejss10126@gmail.com)"

# 같은 호스트에 대한 최소 요청 간격(초). robots.txt의 Crawl-delay가 있으면 더 큰 값이 우선 적용된다.
DEFAULT_REQUEST_DELAY_SECONDS=2.0

# 데이터 저장 위치 (기본값: crawling/data)
DATA_DIR=./data

# OpenAI 기반 정제 설정
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_WAIT=1.5

# trending_word_crawler 테스트/실행 설정
WORD_LIMIT=0

# S3 저장 경로 설정
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
AWS_SESSION_TOKEN=
S3_ENDPOINT_URL=
S3_BUCKET=
S3_RAW_PREFIX=trending-word/raw
S3_ENRICHED_PREFIX=trending-word/enriched

# DB 적재 설정
DATABASE_URL=
DB_SCHEMA=public
DB_TABLE=trending_word_enriched
DB_BATCH_SIZE=100

# 주기 실행(스케줄러) 설정
PIPELINE_ENABLED=true
PIPELINE_SCHEDULE_CRON=0 3 * * *
PIPELINE_TIMEZONE=Asia/Seoul
